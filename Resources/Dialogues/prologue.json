    "mission_brief": {
      "id": "mission_brief",
      "speakerName": "周远",
      "text": "正是因为事关重大，才需要你们二人联手。剑锋经验丰富，沉稳可靠，由他带队。墨尘你机灵聪慧，好生辅佐你师兄。",
      "options": [
        {
          "text": "弟子愿往！定不负师父所托！",
          "targetNodeId": "accept_mission",
          "condition": ""
