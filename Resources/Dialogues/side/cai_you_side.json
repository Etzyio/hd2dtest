    "start": {
      "id": "start",
      "speaker_name": "蔡攸",
      "text": "我义父输，不是因为他错，是因为他还不够狠。",
      "next_node_id": "n2"
    },
    "n2": {
      "id": "n2",
      "speaker_name": "林墨尘",
      "text": "你把狠当本事，把命当草。",
      "next_node_id": "n3"
    },
    "n3": {
      "id": "n3",
      "speaker_name": "蔡攸",
      "text": "江湖和朝堂，本来就都是谁狠谁坐得稳。",
      "next_node_id": "n4"
    },
    "n4": {
      "id": "n4",
      "speaker_name": "林墨尘",
      "text": "那我今天就让你看看，什么叫该狠的时候绝不留人。",
      "next_node_id": ""
    }
  }
