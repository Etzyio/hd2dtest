      "speaker_name": "蔡京",
      "text": "年轻人总爱把自己那点血气，当成天下道理。",
      "next_node_id": "n2"
    },
    "n2": {
      "id": "n2",
      "speaker_name": "林墨尘",
      "text": "你这种人，连杀人都要替自己找块牌坊。",
