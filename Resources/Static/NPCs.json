      "faction": "威远镖局",
      "role": "总镖头",
      "description": "威远镖局总镖头，林墨尘的恩人。二十年前救过蔡京，知道前朝宝藏的秘密。为保护林墨尘而牺牲。",
      "appearance": "魁梧高大，须发半白，面容威严，常穿锦缎长袍，腰间佩着一把古朴宝刀",
      "personality": "正直勇敢，重信重义，深谋远虑",
      "skills": [
        "威远刀法",
        "镖局管理"
      ],
      "defaultScene": "suzhou_biaoju",
      "voiceType": "威严中年",
      "spriteSheet": "zhou_yuan.png",
      "status": "deceased",
      "type": "Villager",
      "isInteractive": true,
      "availableInteractions": [
        "Talk"
      ],
      "detectionRadius": 4.0,
      "dialogue": "走镖的人，先学会看路，再学会看人。",
      "dialogueGraphId": "res://Resources/Dialogues/side/zhou_yuan_side.json",
      "sideDialogues": [
        {
          "id": "side_zhou_yuan_001",
          "sceneId": "suzhou_biaoju",
          "title": "守镖旧训",
          "mood": "quiet",
          "summary": "启程前夜，周远借一壶热茶提醒林墨尘行镖不只是走路，更是守人守心。",
          "availability": "pre_main_story",
          "graphPath": "res://Resources/Dialogues/side/zhou_yuan_side.json",
          "lines": [
            {
              "speaker": "周远",
              "text": "走镖的人，先学会看路，再学会看人。"
            },
            {
              "speaker": "林墨尘",
              "text": "师父是怕我年轻气盛，路上出错？"
            },
            {
              "speaker": "周远",
              "text": "我怕的不是你出错，是你认死理。江湖上的规矩，从来不只写在旗面上。"
            },
            {
              "speaker": "林墨尘",
              "text": "弟子记下了。人能活着回来，镖才算真的送到。"
            }
          ]
        }
      ]
    },
    {
