      "availableInteractions": [
        "Talk"
      ],
      "detectionRadius": 4.0,
      "dialogue": "你出手太快，容易赢，也容易招人惦记。",
      "dialogueGraphId": "res://Resources/Dialogues/side/shen_jianfeng_side.json",
      "sideDialogues": [
        {
          "id": "side_shen_jianfeng_001",
          "sceneId": "qingfeng_men",
          "title": "练剑前夜",
          "mood": "steady",
          "summary": "出发前的练武场，沈剑锋以师兄身份叮嘱林墨尘收锋藏锐。",
          "availability": "pre_huangnigang",
          "graphPath": "res://Resources/Dialogues/side/shen_jianfeng_side.json",
          "lines": [
            {
              "speaker": "沈剑锋",
              "text": "你出手太快，容易赢，也容易招人惦记。"
            },
            {
              "speaker": "林墨尘",
              "text": "师兄的意思，是让我藏一藏？"
            },
            {
              "speaker": "沈剑锋",
              "text": "该藏的时候要藏，该护的时候别退。真到要命处，我挡前头。"
            },
            {
              "speaker": "林墨尘",
              "text": "那我就替师兄看后路。"
            }
          ]
        }
      ]
    },
